# ============================================================
# BHW Report Backend - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# MySQL / XAMPP Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bhw_report_db

# JWT Secret - change this to a long random string in production
JWT_SECRET=bhw_super_secret_key_change_this_in_production_2025
JWT_EXPIRES_IN=8h

# Server
PORT=3000
NODE_ENV=development

# CORS - set to your frontend URL in production
CORS_ORIGIN=*
